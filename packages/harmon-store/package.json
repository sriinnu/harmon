{
  "name": "@sriinnu/harmon-store",
  "version": "0.2.0",
  "description": "SQLite store + migrations for Harmon",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/sriinnu/harmon.git",
    "directory": "packages/harmon-store"
  },
  "homepage": "https://github.com/sriinnu/harmon/tree/main/packages/harmon-store#readme",
  "bugs": {
    "url": "https://github.com/sriinnu/harmon/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "SKILL.md",
    "logo.svg"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node --experimental-strip-types ../../scripts/clean-build.ts ./dist ./tsconfig.tsbuildinfo && tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build",
    "test": "vitest --root ../.. packages/harmon-store/src/index.test.ts",
    "test:run": "vitest --root ../.. run packages/harmon-store/src/index.test.ts",
    "test:coverage": "vitest --root ../.. run --coverage packages/harmon-store/src/index.test.ts"
  },
  "dependencies": {
    "@libsql/client": "^0.17.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/uuid": "^11.0.0",
    "typescript": "^5.9.3"
  }
}
