{
  "name": "@sriinnu/harmon-core",
  "version": "0.1.0",
  "description": "Session engine + ranking + adaptation for Harmon",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/sriinnu/harmon.git",
    "directory": "packages/harmon-core"
  },
  "homepage": "https://github.com/sriinnu/harmon/tree/main/packages/harmon-core#readme",
  "bugs": {
    "url": "https://github.com/sriinnu/harmon/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "SKILL.md",
    "logo.svg"
  ],
  "scripts": {
    "build": "node --experimental-strip-types ../../scripts/clean-build.ts ./dist ./tsconfig.tsbuildinfo && tsc",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "test": "vitest --root ../.. packages/harmon-core/src",
    "test:run": "vitest --root ../.. run packages/harmon-core/src",
    "test:coverage": "vitest --root ../.. run --coverage packages/harmon-core/src"
  },
  "dependencies": {
    "@sriinnu/harmon-protocol": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
