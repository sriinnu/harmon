{
  "name": "@sriinnu/harmon-flow",
  "version": "0.1.0",
  "description": "MCP servers for harmon-flow journal analysis and remote Harmon app integration",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/sriinnu/harmon.git",
    "directory": "packages/harmon-flow"
  },
  "homepage": "https://github.com/sriinnu/harmon/tree/main/packages/harmon-flow#readme",
  "bugs": {
    "url": "https://github.com/sriinnu/harmon/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "SKILL.md",
    "logo.svg"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    },
    "./graph": {
      "types": "./dist/graph/index.d.ts",
      "import": "./dist/graph/index.js"
    }
  },
  "scripts": {
    "build": "node --experimental-strip-types ../../scripts/clean-build.ts ./dist ./tsconfig.tsbuildinfo && tsc",
    "dev": "tsc --watch",
    "start": "node ./dist/mcp/cli.js",
    "start:http": "node ./dist/mcp/cli.js --transport http",
    "start:stdio": "node ./dist/mcp/cli.js --transport stdio",
    "lint": "tsc --noEmit",
    "test": "vitest --root ../.. packages/harmon-flow/src",
    "test:run": "vitest --root ../.. run packages/harmon-flow/src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.2",
    "@sriinnu/harmon-protocol": "workspace:*",
    "gray-matter": "^4.0.3",
    "d3-dag": "^1.1.0",
    "jose": "^6.1.1",
    "uuid": "^13.0.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/uuid": "^11.0.0",
    "@types/node": "^25.0.8",
    "typescript": "^5.9.3"
  }
}
