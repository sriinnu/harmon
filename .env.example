# ============================================================================
# Harmon Daemon Environment Variables
# Copy to .env and fill in your values
#
# SECRETS (tokens, client secrets, private keys) are better kept in the
# macOS Keychain than in this file — harmon falls back to a Keychain lookup
# for any secret variable missing here. See docs/secrets.md:
#   security add-generic-password -s harmon -a <VAR_NAME> -w '<value>' -U
# ============================================================================

# Required in production (or store both in the Keychain — docs/secrets.md)
HARMON_ENCRYPTION_SECRET=   # openssl rand -base64 32
HARMON_API_TOKEN=           # openssl rand -base64 32

# Spotify (at least one auth method required)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:17373/v1/auth/spotify/callback

# Apple Music (optional)
# APPLE_MUSIC_DEVELOPER_TOKEN=
# APPLE_MUSIC_USER_TOKEN=
# APPLE_MUSIC_STOREFRONT=us
# Or for auto-regenerating JWT:
# APPLE_MUSIC_TEAM_ID=
# APPLE_MUSIC_KEY_ID=
# APPLE_MUSIC_PRIVATE_KEY=

# YouTube Music (optional)
# YT_API_KEY=                    # API key for catalog search only
# YOUTUBE_MUSIC_CLIENT_ID=       # For full OAuth
# YOUTUBE_MUSIC_CLIENT_SECRET=   # Required for confidential OAuth clients
# YOUTUBE_MUSIC_REDIRECT_URI=http://127.0.0.1:17373/v1/auth/youtube/callback

# Song recognition (optional)
# AUDD_API_TOKEN=                # https://audd.io/ for commercial recognition
# ACOUSTID_API_KEY=              # For open-source Chromaprint fallback

# CORS — comma-separated explicit origins. Avoid "*": it lets any website
# you visit call the daemon (and it is refused unless HARMON_API_TOKEN is set).
# HARMON_CORS_ORIGINS=http://localhost:4173

# Debugging
# LOG_LEVEL=info                   # debug, info, warn, error

# CLI
# HARMON_ENDPOINT=http://127.0.0.1:17373  # Daemon URL for CLI client
