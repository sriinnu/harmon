{
  "name": "harmon",
  "version": "0.1.0",
  "private": true,
  "description": "Policy-driven music session manager",
  "license": "AGPL-3.0-only",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "verify:pack": "node ./scripts/verify-packages.mjs",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml}\""
  },
  "devDependencies": {
    "@types/node": "^25.0.9",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "prettier": "^3.8.0",
    "supertest": "^7.2.2",
    "turbo": "^2.7.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.28.1"
}
