/**
 * onboarding.ts — First-run setup wizard for the Harmon web app
 *
 * Renders a step-by-step overlay that guides users through:
 * 1. Daemon connection (URL + optional API token)
 * 2. Provider authentication (Spotify, YouTube, Apple)
 * 3. First play (smart search + play)
 *
 * Stores completion state in localStorage. Can be re-triggered via settings.
 *
 * @module onboarding
 */

import { escapeHtml } from './ui.js';

const ONBOARDING_KEY = 'harmon-onboarding-complete';

export interface OnboardingDeps {
  /** Test daemon connection, returns status or throws */
  testConnection(url: string, token?: string): Promise<{ isRunning: boolean; providers?: Record<string, { connected: boolean; status?: string }> }>;
  /** Trigger Spotify OAuth login */
  spotifyLogin(): Promise<{ url: string }>;
  /** Trigger YouTube OAuth login */
  youtubeLogin(): Promise<{ url: string }>;
  /** Set Apple user token */
  appleSetToken(token: string): Promise<{ success: boolean }>;
  /** Smart play a query */
  smartPlay(query: string): Promise<any>;
  /** Called when onboarding completes with configured URL + token */
  onComplete(daemonUrl: string, apiToken: string): void;
}

export function shouldShowOnboarding(): boolean {
  return localStorage.getItem(ONBOARDING_KEY) !== 'true';
}

export function resetOnboarding(): void {
  localStorage.removeItem(ONBOARDING_KEY);
}

export function markOnboardingComplete(): void {
  localStorage.setItem(ONBOARDING_KEY, 'true');
}

export function renderOnboarding(container: HTMLElement, deps: OnboardingDeps): void {
  let currentStep = 0;
  let daemonUrl = 'http://127.0.0.1:17373';
  let apiToken = '';
  let connectedProviders: string[] = [];

  const steps = [
    { id: 'welcome', title: 'Welcome to Harmon', render: renderWelcome },
    { id: 'connect', title: 'Connect to Daemon', render: renderConnect },
    { id: 'providers', title: 'Authenticate Providers', render: renderProviders },
    { id: 'play', title: 'Play Something', render: renderFirstPlay },
  ];

  function render() {
    const step = steps[currentStep];
    container.innerHTML = `
      <div class="onboarding-overlay">
        <div class="onboarding-card">
          <div class="onboarding-progress">
            ${steps.map((s, i) => `<span class="onboarding-dot ${i === currentStep ? 'active' : i < currentStep ? 'done' : ''}"></span>`).join('')}
          </div>
          <h2 class="onboarding-title">${escapeHtml(step.title)}</h2>
          <div class="onboarding-body" id="onboarding-body"></div>
          <div class="onboarding-nav" id="onboarding-nav"></div>
        </div>
      </div>
    `;
    step.render();
  }

  function body(): HTMLElement { return document.getElementById('onboarding-body')!; }
  function nav(): HTMLElement { return document.getElementById('onboarding-nav')!; }

  function nextStep() { if (currentStep < steps.length - 1) { currentStep++; render(); } }
  function prevStep() { if (currentStep > 0) { currentStep--; render(); } }

  // Step 1: Welcome
  function renderWelcome() {
    body().innerHTML = `
      <p>Harmon is a policy-driven music session manager that works with Spotify, Apple Music, and YouTube Music.</p>
      <p>This wizard will help you connect to the daemon and authenticate your music providers.</p>
      <p style="color: var(--muted); font-size: 0.9em; margin-top: 1em;">Takes about 2 minutes.</p>
    `;
    nav().innerHTML = `
      <button class="btn-skip" id="onb-skip">Skip setup</button>
      <button class="btn-primary" id="onb-next">Get started</button>
    `;
    document.getElementById('onb-next')!.addEventListener('click', nextStep);
    document.getElementById('onb-skip')!.addEventListener('click', () => {
      markOnboardingComplete();
      container.innerHTML = '';
    });
  }

  // Step 2: Daemon connection
  function renderConnect() {
    body().innerHTML = `
      <label for="onb-url">Daemon URL</label>
      <input type="url" id="onb-url" value="${escapeHtml(daemonUrl)}" placeholder="http://127.0.0.1:17373" />
      <label for="onb-token">API Token <span style="color: var(--muted)">(optional)</span></label>
      <input type="password" id="onb-token" value="${escapeHtml(apiToken)}" placeholder="Leave empty for local development" />
      <div id="onb-connect-status" class="onboarding-status"></div>
    `;
    nav().innerHTML = `
      <button class="btn-back" id="onb-back">Back</button>
      <button class="btn-primary" id="onb-test">Test Connection</button>
    `;
    document.getElementById('onb-back')!.addEventListener('click', prevStep);
    document.getElementById('onb-test')!.addEventListener('click', async () => {
      const urlInput = document.getElementById('onb-url') as HTMLInputElement;
      const tokenInput = document.getElementById('onb-token') as HTMLInputElement;
      const status = document.getElementById('onb-connect-status')!;
      daemonUrl = urlInput.value.trim();
      apiToken = tokenInput.value.trim();

      status.textContent = 'Testing connection...';
      status.className = 'onboarding-status';
      try {
        const result = await deps.testConnection(daemonUrl, apiToken);
        if (result.isRunning) {
          status.innerHTML = '<span class="status-ok">Connected</span>';
          // Check which providers are already connected
          connectedProviders = [];
          if (result.providers) {
            for (const [name, p] of Object.entries(result.providers)) {
              if (p.connected) connectedProviders.push(name);
            }
          }
          setTimeout(nextStep, 800);
        } else {
          status.innerHTML = '<span class="status-err">Daemon not running</span>';
        }
      } catch (error) {
        status.innerHTML = `<span class="status-err">${escapeHtml(error instanceof Error ? error.message : 'Connection failed')}</span>`;
      }
    });
  }

  // Step 3: Provider auth
  function renderProviders() {
    const providers = [
      { id: 'spotify', name: 'Spotify', icon: '\u{1F3B5}', method: 'oauth' as const },
      { id: 'youtube', name: 'YouTube Music', icon: '\u25B6', method: 'oauth' as const },
      { id: 'apple', name: 'Apple Music', icon: '\u{1F34E}', method: 'token' as const },
    ];

    body().innerHTML = `
      <p style="margin-bottom: 1em;">Connect at least one provider to start listening.</p>
      <div class="provider-list">
        ${providers.map(p => `
          <div class="provider-row" id="onb-provider-${p.id}">
            <span class="provider-icon">${p.icon}</span>
            <span class="provider-name">${p.name}</span>
            <span class="provider-status" id="onb-status-${p.id}">
              ${connectedProviders.includes(p.id) ? '<span class="status-ok">Connected</span>' : 'Not connected'}
            </span>
            <button class="btn-small" id="onb-connect-${p.id}">${connectedProviders.includes(p.id) ? 'Reconnect' : 'Connect'}</button>
          </div>
        `).join('')}
      </div>
      <div id="onb-auth-hint" class="onboarding-hint"></div>
    `;
    nav().innerHTML = `
      <button class="btn-back" id="onb-back">Back</button>
      <button class="btn-primary" id="onb-next">${connectedProviders.length > 0 ? 'Continue' : 'Skip for now'}</button>
    `;

    // Spotify connect
    document.getElementById('onb-connect-spotify')!.addEventListener('click', async () => {
      const hint = document.getElementById('onb-auth-hint')!;
      try {
        const result = await deps.spotifyLogin();
        if (result.url) {
          hint.innerHTML = `<p>Opening Spotify login...<br><a href="${escapeHtml(result.url)}" target="_blank" rel="noopener">Click here if it didn't open</a></p>`;
          window.open(result.url, '_blank', 'noopener,noreferrer');
          document.getElementById('onb-status-spotify')!.innerHTML = '<span class="status-pending">Waiting...</span>';
          // Poll for connection
          await pollProviderStatus('spotify', hint);
        }
      } catch (e) {
        hint.innerHTML = `<span class="status-err">${escapeHtml(e instanceof Error ? e.message : 'Login failed')}</span>`;
      }
    });

    // YouTube connect
    document.getElementById('onb-connect-youtube')!.addEventListener('click', async () => {
      const hint = document.getElementById('onb-auth-hint')!;
      try {
        const result = await deps.youtubeLogin();
        if (result.url) {
          hint.innerHTML = `<p>Opening YouTube login...<br><a href="${escapeHtml(result.url)}" target="_blank" rel="noopener">Click here if it didn't open</a></p>`;
          window.open(result.url, '_blank', 'noopener,noreferrer');
          document.getElementById('onb-status-youtube')!.innerHTML = '<span class="status-pending">Waiting...</span>';
          await pollProviderStatus('youtube', hint);
        }
      } catch (e) {
        hint.innerHTML = `<span class="status-err">${escapeHtml(e instanceof Error ? e.message : 'Login failed')}</span>`;
      }
    });

    // Apple connect (token paste)
    document.getElementById('onb-connect-apple')!.addEventListener('click', () => {
      const hint = document.getElementById('onb-auth-hint')!;
      hint.innerHTML = `
        <label for="onb-apple-token">Paste your MusicKit user token:</label>
        <input type="text" id="onb-apple-token" placeholder="User token from MusicKit JS" style="width: 100%; margin: 0.5em 0;" />
        <button class="btn-small btn-primary" id="onb-apple-submit">Set Token</button>
      `;
      document.getElementById('onb-apple-submit')!.addEventListener('click', async () => {
        const token = (document.getElementById('onb-apple-token') as HTMLInputElement).value.trim();
        if (!token) return;
        try {
          await deps.appleSetToken(token);
          document.getElementById('onb-status-apple')!.innerHTML = '<span class="status-ok">Connected</span>';
          connectedProviders.push('apple');
          hint.innerHTML = '<span class="status-ok">Apple Music connected!</span>';
        } catch (e) {
          hint.innerHTML = `<span class="status-err">${escapeHtml(e instanceof Error ? e.message : 'Failed')}</span>`;
        }
      });
    });

    document.getElementById('onb-back')!.addEventListener('click', prevStep);
    document.getElementById('onb-next')!.addEventListener('click', nextStep);

    async function pollProviderStatus(provider: string, hint: HTMLElement) {
      for (let i = 0; i < 30; i++) {
        await new Promise(r => setTimeout(r, 2000));
        try {
          const connStatus = await deps.testConnection(daemonUrl, apiToken);
          const p = connStatus.providers?.[provider];
          if (p?.connected) {
            document.getElementById(`onb-status-${provider}`)!.innerHTML = '<span class="status-ok">Connected</span>';
            if (!connectedProviders.includes(provider)) connectedProviders.push(provider);
            hint.innerHTML = `<span class="status-ok">${provider} connected!</span>`;
            return;
          }
        } catch { /* keep polling */ }
      }
      hint.innerHTML = `<span class="status-err">Timed out waiting for ${provider}. Complete auth in the browser tab, then click Connect again.</span>`;
    }
  }

  // Step 4: First play
  function renderFirstPlay() {
    body().innerHTML = `
      <p>Try playing something! Search across all your connected providers.</p>
      <div class="smart-play-row">
        <input type="text" id="onb-play-query" placeholder="e.g. Bohemian Rhapsody, lofi beats, ambient..." />
        <button class="btn-primary" id="onb-play-btn">Play</button>
      </div>
      <div id="onb-play-result" class="onboarding-status"></div>
    `;
    nav().innerHTML = `
      <button class="btn-back" id="onb-back">Back</button>
      <button class="btn-primary" id="onb-finish">Finish Setup</button>
    `;

    document.getElementById('onb-play-btn')!.addEventListener('click', async () => {
      const query = (document.getElementById('onb-play-query') as HTMLInputElement).value.trim();
      if (!query) return;
      const result = document.getElementById('onb-play-result')!;
      result.textContent = 'Searching...';
      try {
        const playResult = await deps.smartPlay(query);
        if (playResult.success && playResult.track) {
          result.innerHTML = `<span class="status-ok">Now playing: ${escapeHtml(playResult.track.artist)} — ${escapeHtml(playResult.track.name)} on ${escapeHtml(playResult.provider)}</span>`;
        } else if (playResult.needsAuth) {
          result.innerHTML = `<span class="status-err">${escapeHtml(playResult.provider)} needs authentication. Go back and connect it.</span>`;
        } else {
          result.innerHTML = `<span class="status-err">${escapeHtml(playResult.error || 'No results found')}</span>`;
        }
      } catch (e) {
        result.innerHTML = `<span class="status-err">${escapeHtml(e instanceof Error ? e.message : 'Playback failed')}</span>`;
      }
    });

    // Enter key to play
    document.getElementById('onb-play-query')!.addEventListener('keydown', (e) => {
      if (e.key === 'Enter') document.getElementById('onb-play-btn')!.click();
    });

    document.getElementById('onb-back')!.addEventListener('click', prevStep);
    document.getElementById('onb-finish')!.addEventListener('click', () => {
      markOnboardingComplete();
      deps.onComplete(daemonUrl, apiToken);
      container.innerHTML = '';
    });
  }

  render();
}
