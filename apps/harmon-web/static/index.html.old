<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Harmon Web</title>
    <link rel="stylesheet" href="./styles.css" />
  </head>
  <body>
    <div id="onboarding"></div>
    <main class="shell">
      <header class="hero">
        <p class="eyebrow">Harmon Web</p>
        <h1>I browse and launch Spotify, Apple Music, and YouTube Music.</h1>
      </header>

      <section class="panel controls">
        <label>
          Daemon URL
          <input id="daemon-url" type="url" value="http://127.0.0.1:17373" />
        </label>
        <label>
          API Token
          <input id="api-token" type="password" placeholder="Optional bearer token" />
        </label>
        <p class="hint">I only send bearer tokens to HTTPS or loopback daemon URLs.</p>
        <label>
          Provider
          <select id="provider">
            <option value="spotify">Spotify</option>
            <option value="apple">Apple Music</option>
            <option value="youtube">YouTube Music</option>
          </select>
        </label>
        <div class="actions">
          <button id="refresh-status">Refresh Status</button>
          <button id="previous-button">Prev</button>
          <button id="pause-button">Pause</button>
          <button id="next-button">Next</button>
          <button class="icon-btn" id="reset-onboarding" title="Re-run setup wizard" aria-label="Re-run setup wizard">&#x2699;</button>
        </div>
        <p id="transport-note" class="hint" aria-live="polite"></p>
      </section>

      <section class="panel auth-panel" id="auth-panel" hidden>
        <h3>Provider Auth</h3>
        <div class="provider-auth-grid" id="auth-grid"></div>
      </section>

      <section class="panel session-panel" id="session-panel">
        <h3>Session</h3>
        <div class="session-controls">
          <select id="session-mode">
            <option value="focus">Focus</option>
            <option value="relax">Relax</option>
            <option value="energize">Energize</option>
            <option value="meditate">Meditate</option>
            <option value="workout">Workout</option>
          </select>
          <button class="action-btn" id="session-start">Start Session</button>
          <button class="action-btn" id="session-nudge-calmer" disabled>Calmer</button>
          <button class="action-btn" id="session-nudge-sharper" disabled>Sharper</button>
          <button class="action-btn danger" id="session-stop" disabled>Stop</button>
        </div>
        <div id="session-status" class="session-status-text"></div>
      </section>

      <section class="panel smart-panel">
        <h3>Smart Play</h3>
        <form class="smart-play-form" id="smart-play-form">
          <input type="text" id="smart-query" placeholder="Play anything — searches all providers" aria-label="Smart play search" />
          <button type="submit" class="action-btn accent">Play</button>
        </form>
        <div id="smart-result" aria-live="polite"></div>
      </section>

      <section class="panel">
        <h2>Status</h2>
        <div id="status" role="status" aria-live="polite"></div>
        <div id="now-playing" role="status" aria-live="polite"></div>
        <p id="error" class="error" role="alert" aria-live="assertive"></p>
      </section>

      <section class="panel">
        <h2>Search</h2>
        <form id="search-form" class="search-bar">
          <label class="sr-only" for="search-query">Search query</label>
          <input id="search-query" type="search" placeholder="Search tracks, albums, artists, playlists" />
          <label class="sr-only" for="search-kind">Search kind</label>
          <select id="search-kind">
            <option value="song">Song</option>
            <option value="album">Album</option>
            <option value="artist">Artist</option>
            <option value="playlist">Playlist</option>
          </select>
          <button id="search-button" type="submit">Search</button>
        </form>
        <div id="search-results" class="grid"></div>
      </section>

      <section class="panel">
        <div class="section-header">
          <h2>Library</h2>
          <button id="load-library">Load Library</button>
        </div>
        <div id="library-results" class="grid"></div>
      </section>

      <section class="panel">
        <div class="section-header">
          <h2>Playlists</h2>
          <button id="load-playlists">Load Playlists</button>
        </div>
        <div id="playlists" class="grid"></div>
      </section>

      <section class="panel">
        <h2>Playlist Tracks</h2>
        <p id="playlist-context" class="panel-subtle"></p>
        <div id="playlist-tracks" class="grid"></div>
      </section>
    </main>

    <script type="module" src="./app.js"></script>
  </body>
</html>
