{
  "name": "@sriinnu/harmon",
  "version": "0.3.0",
  "description": "Harmon \u2014 CLI + daemon for policy-driven music sessions across Spotify, Apple Music, and YouTube Music",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/sriinnu/harmon.git",
    "directory": "apps/harmon-cli"
  },
  "homepage": "https://github.com/sriinnu/harmon/tree/main/apps/harmon-cli#readme",
  "bugs": {
    "url": "https://github.com/sriinnu/harmon/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "README.md",
    "SKILL.md",
    "logo.svg"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "harmon": "./dist/bin/harmon.js",
    "harmond": "./dist/bin/harmond.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node --experimental-strip-types ../../scripts/clean-build.ts ./dist ./tsconfig.tsbuildinfo && tsc && pnpm build:bundle",
    "build:bundle": "node --experimental-strip-types scripts/bundle.ts",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm build && pnpm build:bundle",
    "test": "vitest --root ../.. apps/harmon-cli/bin/runtime.test.js apps/harmon-cli/src/index.test.ts",
    "test:run": "vitest --root ../.. run apps/harmon-cli/bin/runtime.test.js apps/harmon-cli/src/index.test.ts"
  },
  "dependencies": {
    "commander": "^14.0.2",
    "@libsql/client": "^0.17.0"
  },
  "devDependencies": {
    "@sriinnu/harmon-protocol": "workspace:*",
    "@types/node": "^25.0.8",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.3",
    "@sriinnu/harmond": "workspace:*"
  }
}
