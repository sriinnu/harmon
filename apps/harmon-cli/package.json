{
  "name": "@athena/harmon",
  "version": "0.1.0",
  "description": "CLI client for Harmon daemon",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "bin/harmon.js",
    "bin/runtime.js",
