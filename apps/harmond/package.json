{
  "name": "@athena/harmond",
  "version": "0.1.0",
  "description": "Harmon daemon - multi-provider engine, store, and playback runtime",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "files": [
    "bin/harmond.js",
    "dist/",
    "README.md",
    "SKILL.md",
    "logo.svg"
  ],
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "bin": {
    "harmond": "./bin/harmond.js"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc --watch",
    "start": "node ./dist/src/index.js",
    "lint": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@athena/harmon-protocol": "workspace:*",
    "@athena/harmon-store": "workspace:*",
    "@athena/harmon-core": "workspace:*",
    "@athena/harmon-spotify": "workspace:*",
    "@athena/harmon-apple": "workspace:*",
    "@athena/harmon-youtube": "workspace:*",
    "@athena/harmon-logger": "workspace:*",
    "@athena/harmon-crypto": "workspace:*",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.8",
    "@types/uuid": "^11.0.0",
    "typescript": "^5.9.3"
  }
}
